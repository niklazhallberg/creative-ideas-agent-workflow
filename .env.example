# Kopiera till .env (som är gitignored) och fyll i de nycklar du faktiskt behöver.
# Inget av detta är obligatoriskt för att klona/installera repot.

# Primär leverantör i Fas 0 (för AI-baseline-generering)
ANTHROPIC_API_KEY=

# Övriga leverantörer — fylls i när multi-provider blir en aktiv experimentvariabel
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Slack-bot för feedback-loopen (Fas 4). Se ADR 0004 för hur den skapas.
# Botten behöver scopes: channels:history, reactions:read, chat:write
SLACK_BOT_TOKEN=
# Kanal-id för #radon-ideation (där idéer postas)
SLACK_IDEATION_CHANNEL=
